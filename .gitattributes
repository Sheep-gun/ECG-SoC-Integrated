# Integration-authored text remains normalized in Git.
*.md text eol=lf
*.py text eol=lf
*.csv text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.svg text eol=lf
*.pdf binary

# Imported component snapshots override generic rules and preserve exact bytes.
/components/** -text !eol
