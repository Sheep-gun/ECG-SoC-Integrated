# Integration-authored text remains normalized in Git.
*.md text eol=lf
*.py text eol=lf
*.csv text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.svg text eol=lf
*.pdf binary

# Imported component snapshots override generic rules and preserve their native
# line endings. CRLF is therefore a valid end-of-line sequence in redacted
# public copies and must not be reported as trailing whitespace.
/components/** -text !eol whitespace=cr-at-eol
